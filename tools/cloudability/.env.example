# Cloudability by IBM — API Credentials
# Copy to .env and fill in the values. NEVER commit .env.

# Cloudability API token (generate at: https://app.cloudability.com/settings/api)
CLOUDABILITY_API_TOKEN=your_token_here

# Optional: restrict to specific vendor(s). Leave blank for all clouds.
# Values: AWS, GCP, Azure (comma-separated)
CLOUDABILITY_VENDORS=

# Optional: date range override (YYYY-MM-DD). Defaults to yesterday.
CLOUDABILITY_DATE_FROM=
CLOUDABILITY_DATE_TO=

# Slack webhook for daily digest posting (optional)
SLACK_WEBHOOK_URL=
