# GCP Billing Cost Management — Required Environment Variables
# Service Account: grpn-sa-billing-cost-mgmt@prj-grp-central-sa-prod-0b25.iam.gserviceaccount.com
#
# NEVER commit the filled .env to git. This file is the template only.
#
# To set up:
#   1. Download the service account JSON key from GCP Console
#      (rotate the exposed key first — see SECURITY NOTE below)
#   2. Save the JSON as tools/gcp-billing/service-account-key.json
#   3. Copy this file to .env and fill in the values
#
# SECURITY NOTE: If any key in this file was ever committed or shared,
# rotate it immediately at:
#   GCP Console → IAM & Admin → Service Accounts → grpn-sa-billing-cost-mgmt → Keys

# Path to the service account JSON key file (relative to workspace root)
GOOGLE_APPLICATION_CREDENTIALS=tools/gcp-billing/service-account-key.json

# GCP project that owns the billing export BigQuery dataset
GCP_BILLING_PROJECT=prj-grp-billing-prod

# BigQuery dataset name for billing export
# Find at: GCP Console → Billing → Billing export → BigQuery export → Dataset name
GCP_BILLING_DATASET=all_billing_export

# Billing account display name (used for filtering)
GCP_BILLING_ACCOUNT_NAME=GCP Landing Zone

# Slack webhook URL for daily digest posting (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email recipients for daily digest (comma-separated, optional)
# DIGEST_EMAIL_RECIPIENTS=pmunjal@groupon.com,platform-finops@groupon.com
